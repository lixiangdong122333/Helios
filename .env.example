# Shared Cloud Logging settings. If omitted, the ADC quota project is discovered.
HELIOS_DEFAULT_PROJECTS=my-gcp-project
HELIOS_MAX_QUERY_WINDOW_HOURS=168
HELIOS_MAX_QUERY_ENTRIES=200
HELIOS_MAX_SCAN_ENTRIES=5000
HELIOS_MAX_RESPONSE_BYTES=1000000
HELIOS_MAX_ENTRY_BYTES=16000
HELIOS_QUERY_TIMEOUT_MS=30000
# HELIOS_REDACT_KEYS=session_id,private_key
HELIOS_LOG_LEVEL=info
HELIOS_MAX_CONCURRENT_QUERIES=4
HELIOS_RATE_LIMIT_REQUESTS=60
HELIOS_RATE_LIMIT_WINDOW_SECONDS=60

# Transport: stdio or http. The CLI --transport flag takes precedence.
HELIOS_TRANSPORT=stdio

# Streamable HTTP settings.
HELIOS_HTTP_HOST=127.0.0.1
HELIOS_HTTP_PORT=48080
HELIOS_HTTP_PATH=/mcp
HELIOS_HTTP_PUBLIC_URL=http://127.0.0.1:48080/mcp
HELIOS_HTTP_ALLOWED_ORIGINS=http://127.0.0.1:48080
HELIOS_HTTP_PREAUTH_RATE_LIMIT_REQUESTS=120
HELIOS_HTTP_PREAUTH_RATE_LIMIT_WINDOW_SECONDS=60
# Required with HELIOS_HTTP_HOST=0.0.0.0, for example: logs.example.com
# HELIOS_HTTP_ALLOWED_HOSTS=logs.example.com

# Authentication is mandatory in HTTP mode: static or oidc.
HELIOS_HTTP_AUTH_MODE=static
HELIOS_HTTP_STATIC_TOKENS_JSON={"local-operator":"replace-with-a-long-random-secret"}

# OIDC/JWKS mode settings.
# HELIOS_HTTP_AUTH_MODE=oidc
# HELIOS_OIDC_ISSUER=https://issuer.example.com/
# HELIOS_OIDC_AUDIENCE=https://helios.example.com/mcp
# HELIOS_OIDC_JWKS_URI=https://issuer.example.com/.well-known/jwks.json
# HELIOS_OIDC_ALGORITHMS=RS256,ES256
# HELIOS_OIDC_REQUIRED_SCOPES=logs.read
